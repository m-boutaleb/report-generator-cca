# Copy to .env on the server and fill in real values:
#   cp .env.example .env
#
# Priority in the app: environment variables > secrets.json > defaults.
# Do NOT commit .env (it is gitignored).

# --- Image ---
IMAGE=ghcr.io/m-boutaleb/report-generator-cca
IMAGE_TAG=1.0.0
HOST_PORT=8000

# --- Required: Metabase (CSV download) ---
METABASE_API_KEY=mb_REPLACE_ME

# --- Required: Google GenAI / Gemini (prose generation) ---
GEMINI_API_KEY=AIzaSyREPLACE_ME
# Alternative key name (used if GEMINI_API_KEY is empty):
# GOOGLE_API_KEY=AIzaSyREPLACE_ME

# Model used by test_google_ai.py / pipeline / API
GEMINI_MODEL=gemma-4-31b-it

# --- Optional: Gemini rate limiting / retries ---
GEMINI_MAX_CALLS_PER_MINUTE=5
GEMINI_RATE_WINDOW_SECONDS=60
GEMINI_MIN_PAUSE_SECONDS=60
API_RETRY_MAX_ATTEMPTS=6
API_RETRY_BASE_DELAY=5
API_RETRY_MAX_DELAY=120

# --- Optional: local Ollama path (only if you call generate_offerta_text.py) ---
# In Docker, 127.0.0.1 is the container itself — use host.docker.internal
# or the Ollama service hostname on your network when needed.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4
OLLAMA_TEMPERATURE=0.3
OLLAMA_NUM_PREDICT=2048
